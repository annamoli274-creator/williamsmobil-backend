# Resend
RESEND_API_KEY=your_re_key_here
RESEND_FROM="Williams Mobil <contact@williamsmobilhome.com>"
RESEND_TIMEOUT_MS=15000
RESEND_RETRY_ATTEMPTS=2

# Optional SMTP fallback (IONOS) - only used if Resend fails
SMTP_HOST=smtp.ionos.fr
SMTP_PORT=587
SMTP_USER=contact@williamsmobilhome.com
SMTP_PASS=your_ionos_password
SMTP_SECURE=false

# Local/dev helpers
SKIP_EMAIL_SEND=false
