{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*.ts", "server.ts"],
  "exclude": ["node_modules"]
}
