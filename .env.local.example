# Backend API URL
# In Next.js, variables must be prefixed with NEXT_PUBLIC_ to be accessible
# at runtime (both server-side API routes and client-side code).
#
# Development: defaults to http://localhost:5001 if this variable is not set.
# Production (Vercel): set this to your Railway backend URL.
#   e.g. NEXT_PUBLIC_BACKEND_URL=https://williamsmobil-backend.railway.app
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001
